# Copy to keystore.properties in this directory (android/) — never commit keystore.properties.
# Generate keystore once, e.g.:
#   mkdir -p keystore
#   keytool -genkeypair -v -keystore keystore/aegis-release.keystore -alias aegis \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Paths are relative to android/app/

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=aegis
storeFile=../keystore/aegis-release.keystore
