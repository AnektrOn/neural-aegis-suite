# Copy to .env.production for production Vite/Capacitor builds (do not commit real values).
# Same variables as local dev; Vite embeds these at build time.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# Supabase Dashboard → Authentication → URL configuration:
# Add redirect / site URL allowances used by Capacitor WebView, e.g.:
#   capacitor://localhost
#   http://localhost
#   https://localhost
# Add OAuth redirect URLs if you use social login.
